{
  "name": "shackleai-orchestrator",
  "version": "0.0.0",
  "private": true,
  "description": "The Operating System for AI Agents — open-source agent orchestrator",
  "license": "MIT",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:e2e": "vitest run --config tests/vitest.config.ts",
    "test:browser": "playwright test",
    "test:browser:ui": "playwright test --ui",
    "test:browser:debug": "PWDEBUG=1 playwright test --debug",
    "test:browser:codegen": "playwright codegen http://localhost:5173",
    "test:browser:seed": "tsx tests/browser/seed-visual.ts",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml}\"",
    "release": "changeset publish",
    "version-packages": "changeset version",
    "docs:dev": "cd website && npm start",
    "docs:build": "cd website && npm run build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
